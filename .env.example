# Binance API Credentials (for Crypto trading)
BINANCE_API_KEY=your_api_key_here
BINANCE_API_SECRET=your_api_secret_here

# Portfolio Configuration (Required for stocks/indices if not using live broker API)
# Set your total portfolio equity value in INR or USD
PORTFOLIO_EQUITY=100000

# Market Data Provider Config
MARKET_DATA_PROVIDER=binance

# News & Sentiment (Recommended: Alpha Vantage)
ALPHA_VANTAGE_API_KEY=your_alpha_vantage_key_here

# LLM / AI Config
ANTHROPIC_API_KEY=your_anthropic_key_here

# Signal Parsing (LLM Fallback - Optional)
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL_NAME=llama-3.3-70b-versatile
